# ============================================================
# FLUX Theme — .gitignore
# Works for both development and production environments
# ============================================================

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ─── Virtual Environment ───
env/
venv/
.venv/
ENV/

# ─── Compiled CSS (regenerated via npx sass) ───
# Keep in repo for production — built CSS is needed for bench build
# flux_theme/public/css/flux.css
# flux_theme/public/css/flux.css.map

# ─── Node.js ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json
yarn.lock

# ─── IDE / Editor ───
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ─── OS Files ───
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Frappe / Bench ───
# These are generated by bench and should not be committed
sites/
*.pyc
.bench/

# ─── Logs ───
logs/
*.log
*.log.*

# ─── Test / Coverage ───
.coverage
.tox
.nox
htmlcov/
.pytest_cache/
.mypy_cache/

# ─── Temporary Files ───
*.tmp
*.bak
*.backup
*.orig
*.save
tmp/
temp/

# ─── Secrets / Config ───
# Never commit site-specific config
site_config.json
common_site_config.json
*.pem
*.key
*.cert
.env
.env.local
.env.production

# ─── Docker ───
docker-compose.override.yml

# ─── Archives ───
*.tar.gz
*.zip
*.rar
*.7z

# ─── Media uploads (if any) ───
flux_theme/public/files/
